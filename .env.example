# Koneksi PostgreSQL untuk Prisma.
#
# Dev lokal:
#   Container Supabase lokal di port 54322.
#   DATABASE_URL="postgresql://postgres:postgres@localhost:54322/investasi_syariah"
#
# Produksi (Netlify + Supabase cloud):
#   Ambil connection string "Transaction pooler" (port 6543) dari dashboard Supabase
#   (Project Settings -> Database -> Connection string -> Transaction pooler),
#   lalu set sebagai environment variable DATABASE_URL di Netlify
#   (Site settings -> Environment variables). JANGAN commit nilai aslinya.
#
#   Contoh format pooler Supabase (serverless-friendly):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

DATABASE_URL="postgresql://postgres:postgres@localhost:54322/investasi_syariah"
